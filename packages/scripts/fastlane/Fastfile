require "tmpdir"

default_platform(:ios)

platform :ios do
  desc "Archive and upload the Expo iOS app from GitHub Actions"
  lane :ci_build do
    app_path = ENV["APP_PATH"]
    UI.user_error!("APP_PATH is required") if app_path.to_s.empty?

    repo_root = File.expand_path("../../..", __dir__)
    app_root = File.expand_path(app_path, repo_root)

    ios_path = File.join(app_root, "ios")
    workspaces = Dir[File.join(ios_path, "*.xcworkspace")]
    xcodeproj = Dir[File.join(ios_path, "*.xcodeproj")].first
    UI.user_error!("Expected exactly one Xcode workspace in #{ios_path}, found #{workspaces.length}") unless workspaces.length == 1
    UI.user_error!("Xcode project not found at #{ios_path}") if xcodeproj.nil?

    # Extract app_identifier from the project.pbxproj using a regex
    pbxproj_path = File.join(xcodeproj, "project.pbxproj")
    app_identifier = File.read(pbxproj_path)[/PRODUCT_BUNDLE_IDENTIFIER\s*=\s*([^;]+);/, 1]&.strip
    UI.user_error!("app_identifier not found in project.pbxproj") if app_identifier.to_s.empty?

    scheme = File.basename(workspaces.first, ".xcworkspace")

    # Capture environment variables for validation and reuse
    key_id = ENV["APP_STORE_CONNECT_KEY_ID"]
    issuer_id = ENV["APP_STORE_CONNECT_ISSUER_ID"]
    private_key = ENV["APP_STORE_CONNECT_PRIVATE_KEY"]
    UI.user_error!("APP_STORE_CONNECT_KEY_ID is required") if key_id.to_s.empty?
    UI.user_error!("APP_STORE_CONNECT_ISSUER_ID is required") if issuer_id.to_s.empty?
    UI.user_error!("APP_STORE_CONNECT_PRIVATE_KEY is required") if private_key.to_s.empty?

    api_key = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_content: private_key.gsub("\\n", "\n"),
      is_key_content_base64: false,
      in_house: false,
    )

    setup_ci if ENV["CI"] == "true"

    build_app(
      workspace: workspaces.first,
      scheme: scheme,
      archive_path: File.join(Dir.tmpdir, "#{scheme}.xcarchive"),
      export_method: "app-store-connect",
      export_options: {
        signingStyle: "automatic",
      },
      output_directory: File.join(Dir.tmpdir, "exported-ios"),
      output_name: "#{scheme}.ipa",
      xcargs: "-allowProvisioningUpdates -authenticationKeyPath '#{api_key[:key_filepath]}' -authenticationKeyID '#{key_id}' -authenticationKeyIssuerID '#{issuer_id}'",
    )

    ipa_path = Actions.lane_context[SharedValues::IPA_OUTPUT_PATH]
    UI.user_error!("Fastlane did not produce an IPA") if ipa_path.to_s.empty?

    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      notify_external_testers: false,
    )

    github_output = ENV["GITHUB_OUTPUT"]
    return if github_output.to_s.empty?

    File.open(github_output, "a") { |f| f.puts("ipa_path=#{ipa_path}") }
  end
end
